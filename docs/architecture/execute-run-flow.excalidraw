      "index": "a12",
      "roundness": null,
      "fontSize": 11,
      "fontFamily": 1,
      "text": "Phase 6: RUN BENCHMARK (with engine_watchdog + concurrency semaphore)\n\nStatus: running\nsemaphore = asyncio.Semaphore(config.concurrency)\nwatchdog = asyncio.create_task(engine_watchdog(...))  ← polls is_healthy() every 10s\n\nasync def run_one(prompt):\n  async with semaphore:  ← limits concurrency\n    for attempt in range(1, config.auto_retry + 2):\n      try:\n        record = await collect_record(driver, config, prompt, run_id, attempt)\n        db.insert(record)\n        increment_completed()\n        return\n      except Exception as e:\n        if attempt > config.auto_retry: → record_error() and increment_failed()\n        else: await asyncio.sleep(1 * attempt)  ← linear backoff",
      "baseline": 124,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "phase6-box",
      "originalText": "Phase 6: RUN BENCHMARK (with engine_watchdog + concurrency semaphore)\n\nStatus: running\nsemaphore = asyncio.Semaphore(config.concurrency)\nwatchdog = asyncio.create_task(engine_watchdog(...))  ← polls is_healthy() every 10s\n\nasync def run_one(prompt):\n  async with semaphore:  ← limits concurrency\n    for attempt in range(1, config.auto_retry + 2):\n      try:\n        record = await collect_record(driver, config, prompt, run_id, attempt)\n        db.insert(record)\n        increment_completed()\n        return\n      except Exception as e:\n        if attempt > config.auto_retry: → record_error() and increment_failed()\n        else: await asyncio.sleep(1 * attempt)  ← linear backoff",
      "baseline": 124,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "phase6-box",
      "originalText": "Phase 6: RUN BENCHMARK (with engine_watchdog + concurrency semaphore)\n\nStatus: running\nsemaphore = asyncio.Semaphore(config.concurrency)\nwatchdog = asyncio.create_task(engine_watchdog(...))  ← polls is_healthy() every 10s\n\nasync def run_one(prompt):\n  async with semaphore:  ← limits concurrency\n    for attempt in range(1, config.auto_retry + 2):\n      try:\n        record = await collect_record(driver, config, prompt, run_id, attempt)\n        db.insert(record)\n        increment_completed()\n        return\n      except Exception as e:\n        if attempt > config.auto_retry: → record_error() and increment_failed()\n        else: await asyncio.sleep(1 * attempt)  ← linear backoff",
      "lineHeight": 1.25,
      "isDeleted": false
    },
