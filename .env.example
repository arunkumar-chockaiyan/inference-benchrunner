# ── Secrets (required — no defaults; generate before first run) ───────────────
#
# PostgreSQL password (used by both postgres service and backend DATABASE_URL)
# generate: python -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=changeme-replace-with-random

# Agent shared key — must match on every agent host (local + remote Tailscale)
# generate: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_SECRET_KEY=changeme-replace-with-32-random-bytes

# Grafana admin password
# generate: python -c "import secrets; print(secrets.token_hex(16))"
GRAFANA_ADMIN_PASSWORD=changeme-replace-with-random

# ── App backend ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bench:${POSTGRES_PASSWORD}@postgres:5432/bench
OTEL_COLLECTOR_ENDPOINT=http://otel-collector:4317
# On Linux host (sidecar outside Docker): use 127.0.0.1:4317
# (otel-collector ports are now bound to 127.0.0.1 only)
VICTORIAMETRICS_URL=http://victoriametrics:8428
GRAFANA_URL=http://localhost:3001   # browser-facing — must be reachable by the user's browser
                                    # change to host IP if accessing from another machine
SECRET_KEY=changeme-replace-with-32-random-bytes  # reserved for future user auth, unused Phase 1

# ── Agent ─────────────────────────────────────────────────────────────────────
# For local docker-compose the agent is on bench-net at http://agent:8787.
# For remote machines, host comes from RunConfig.host (Tailscale IP/MagicDNS).
AGENT_URL=http://agent:8787

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123

# ── Remote via Tailscale ──────────────────────────────────────────────────────
# RunConfig.host should be a Tailscale IP (100.x.x.x) or MagicDNS (*.ts.net)
# Default agent port: 8787 — override per-run via RunConfig.agent_port

# ── Ollama shim (set by backend at runtime — do not set manually) ─────────────
RUN_ID=
MODEL_NAME=

# ── Phase 3 (do not set until Phase 3 triggered) ─────────────────────────────
# KAFKA_BROKERS=kafka:9092
