      "index": "a16",
      "roundness": null,
      "fontSize": 11,
      "fontFamily": 1,
      "text": "stream_prompt(prompt, run_id, params) → AsyncIterator[str | ResponseMeta]\n  Calls engine directly: POST {config.host}:{config.port}/v1/completions\n  Agent is NOT involved — request goes straight to engine\n  All 4 drivers use OpenAI-compatible API (except Ollama special cases)\n  Returns token chunks + final ResponseMeta (token counts, engine TPS)",
      "baseline": 64,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "data-plane-box",
      "originalText": "stream_prompt(prompt, run_id, params) → AsyncIterator[str | ResponseMeta]\n  Calls engine directly: POST {config.host}:{config.port}/v1/completions\n  Agent is NOT involved — request goes straight to engine\n  All 4 drivers use OpenAI-compatible API (except Ollama special cases)\n  Returns token chunks + final ResponseMeta (token counts, engine TPS)",
      "lineHeight": 1.25,
      "isDeleted": false
    },
