    {
      "id": "collect-record-text",
      "type": "text",
      "x": 65,
      "y": 515,
      "width": 860,
      "height": 90,
      "angle": 0,
      "strokeColor": "#065f46",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a14",
      "roundness": null,
      "fontSize": 11,
      "fontFamily": 1,
      "text": "collect_record(driver, config, prompt, run_id, attempt) → RequestRecord\n\nrendered = render_prompt(prompt, config.variable_overrides)\nparams = PromptParams(temp, max_tokens, top_p, timeout_s)\nstart = time.perf_counter()\n\nasync for chunk in driver.stream_prompt(rendered, str(run_id), params):\n  if isinstance(chunk, ResponseMeta): meta = chunk  ← exact token counts from engine\n  else: chunks.append(chunk)  ← accumulate tokens\n\ntotal_ms = wall-clock latency\nttft_ms = time to first non-whitespace token (or None)\ntokens_per_second = meta.engine_tps or wall_tps  ← prefer engine-reported TPS",
      "baseline": 84,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "collect-record-box",
      "originalText": "collect_record(driver, config, prompt, run_id, attempt) → RequestRecord\n\nrendered = render_prompt(prompt, config.variable_overrides)\nparams = PromptParams(temp, max_tokens, top_p, timeout_s)\nstart = time.perf_counter()\n\nasync for chunk in driver.stream_prompt(rendered, str(run_id), params):\n  if isinstance(chunk, ResponseMeta): meta = chunk  ← exact token counts from engine\n  else: chunks.append(chunk)  ← accumulate tokens\n\ntotal_ms = wall-clock latency\nttft_ms = time to first non-whitespace token (or None)\ntokens_per_second = meta.engine_tps or wall_tps  ← prefer engine-reported TPS",
      "lineHeight": 1.25,
      "isDeleted": false
    },
