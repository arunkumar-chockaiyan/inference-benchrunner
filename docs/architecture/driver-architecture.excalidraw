    {
      "id": "agent-text",
      "type": "text",
      "x": 70,
      "y": 345,
      "width": 460,
      "height": 110,
      "angle": 0,
      "strokeColor": "#1e40af",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
