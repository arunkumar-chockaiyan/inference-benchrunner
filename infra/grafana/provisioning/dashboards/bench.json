    },
    {
      "id": 8,
      "title": "GPU utilisation",
      "description": "Requires DCGM exporter",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "VictoriaMetrics",
          "expr": "avg by (run_id, gpu) (DCGM_FI_DEV_GPU_UTIL{run_id=~\"$run_id\"})",
          "legendFormat": "{{run_id}} gpu{{gpu}}",
          "refId": "A"
        }
